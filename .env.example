# ─────────────────────────────────────────────────────────────────────
# .env.example — TEMPLATE เท่านั้น ห้ามใส่ค่าจริงลงไฟล์นี้ และห้าม commit .env
#
# วิธีใช้ (local dev เท่านั้น):
#   1) copy เป็น .env  ->  cp .env.example .env
#   2) เติมค่าจริงใน .env (ไฟล์ .env ถูก .gitignore ไว้แล้ว)
#
# บน production: ค่าที่เป็น "ความลับ" (MONGODB_URI, GCHAT_WEBHOOK_URL)
# จะถูก inject จาก Secret Manager เข้ามาเป็น env var โดย Cloud Run
# ไม่ต้องมีไฟล์ .env บน production
# ─────────────────────────────────────────────────────────────────────

# ── ความลับ (บน prod มาจาก Secret Manager) ───────────────────────────
# MongoDB Atlas connection string (SRV) ของ user แบบ read-only เท่านั้น — B2C server
MONGODB_URI="mongodb+srv://readonly_user:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&tls=true"
# B2B Mongo server (คนละ server) — read-only เช่นกัน
MONGODB_URI_B2B="mongodb+srv://readonly_user:PASSWORD@b2b-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority&tls=true"
# Google Chat incoming webhook URL (มี key + token — เป็นความลับ)
GCHAT_WEBHOOK_URL="https://chat.googleapis.com/v1/spaces/XXXX/messages?key=XXXX&token=XXXX"

# ── GCP / BigQuery (B2C / B2B แยก dataset) ───────────────────────────
GCP_PROJECT_ID="your-gcp-project-id"
BQ_LOCATION="asia-southeast1"
BQ_DATASET="B2C"                         # dataset ฝั่ง B2C
BQ_DATASET_B2B="B2B"                     # dataset ฝั่ง B2B
BQ_DATASET_TOTAL="Total"                 # dataset ของ view รวม
BQ_TABLE="user_usage_event"
BQ_STATE_TABLE="pipeline_state"
BQ_TOTAL_VIEW="user_tracking_total"      # view รวม B2C+B2B

# ── MongoDB (ชื่อ db/collection เหมือนกันทั้ง 2 server) ───────────────
MONGO_DB="credit_service"
MONGO_COLLECTION="user_usage_event"
MONGO_PACKAGE_COLLECTION="package_master_v3"
MONGO_USERS_DB="Librechat"               # users/company/team อยู่ใน db นี้
MONGO_USERS_COLLECTION="users"
MONGO_COMPANY_COLLECTION="b2b_company"   # B2B เท่านั้น
MONGO_TEAM_COLLECTION="b2b_team"         # B2B เท่านั้น

# ── BigQuery: ตารางเพิ่มเติม ─────────────────────────────────────────
BQ_PACKAGE_TABLE="package_master_v3"     # master table (lean)
BQ_USERS_TABLE="librechat_users"         # B2C: userId+isBanned / B2B: userId+team
BQ_COMPANY_TABLE="b2b_company"           # B2B master
BQ_TEAM_TABLE="b2b_team"                 # B2B master
BQ_B2C_TABLE="user_tracking_b2c"         # aggregate B2C
BQ_B2B_TABLE="user_tracking_b2b"         # aggregate B2B

# ── Pipeline logic ───────────────────────────────────────────────────
# timezone สำหรับสกัด date_id และนิยาม "วัน"
PIPELINE_TIMEZONE="Asia/Bangkok"
# วันแรกสุดที่จะดึง (ขอบล่าง hard limit)
START_DATE="2026-01-01"
# reprocess ย้อนหลังกี่วันต่อรอบ (เผื่อ event มาช้า)
LOOKBACK_DAYS="1"
# อัตราแลกเปลี่ยน USD -> THB (constant; เผื่อย้ายไป API ภายหลัง)
EXCHANGE_RATE="32.67"
# buffer (ชม.) ของ _id-range filter เพื่อยืม default _id index (ไม่ต้องสร้าง index ใหม่)
# 24 = เผื่อ ±1 วันรอบช่วง event (ปลอดภัยสำหรับ event ที่เขียน real-time)
# 0  = ปิด แล้วกรองด้วย eventTimeStamp ล้วน (ถูก 100% แต่ scan ทั้ง collection)
ID_INDEX_BUFFER_HOURS="24"

# ── IP drift guard ───────────────────────────────────────────────────
# static egress IP ที่คาดหวัง (ค่าได้จาก deploy.sh ตอนจอง reserved IP)
# ถ้า egress จริงไม่ตรงค่านี้ -> แจ้งเตือน (whitelist อาจหลุด)
EXPECTED_EGRESS_IP="x.x.x.x"
